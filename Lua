-- ══════════════════════════════════════════
--  KEY SCREEN
-- ══════════════════════════════════════════
local keySuccess = false

local function showKeyScreen()
    KeyFrame.Visible = true
    -- Fade in all elements
    for _, obj in ipairs(KeyFrame:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            obj.TextTransparency = 1
            tw(obj, { TextTransparency = 0 }, 0.35)
        elseif obj:IsA("Frame") then
            obj.BackgroundTransparency = 1
            tw(obj, { BackgroundTransparency = 0 }, 0.35)
        end
    end
    InputBG.BackgroundTransparency = 0
    tw(FootTxt, { TextTransparency = 0 }, 0.4)

    -- Key validation
    local done = false
    SubmitBtn.MouseButton1Click:Connect(function()
        if done then return end
        local entered = KeyBox.Text:upper():gsub("%s", "")
        local valid   = CONFIG.VALID_KEY:upper():gsub("%s", "")

        if entered == valid then
            done = true
            keySuccess = true
            tw(InputBG, { BackgroundColor3 = Color3.fromRGB(5, 18, 5) }, 0.3)
            KeyHint.Text = "✓  Key accepted"
            tw(KeyHint, { TextColor3 = CONFIG.COL_SUCCESS }, 0.3)
            task.wait(0.7)
        else
            -- Wrong key: shake + red tint
            tw(InputBG, { BackgroundColor3 = Color3.fromRGB(18, 5, 5) }, 0.2)
            tw(KeyHint, { TextColor3 = CONFIG.COL_ERROR }, 0.2)
            KeyHint.Text = "✗  Invalid key — "..CONFIG.KEY_HINT

            -- Small shake animation
            local origX = InputBG.Position.X.Offset
            for i = 1, 4 do
                tw(InputBG, { Position = UDim2.fromOffset(origX + (i%2==0 and 5 or -5), 18) }, 0.05)
                task.wait(0.06)
            end
            tw(InputBG, { Position = UDim2.fromOffset(origX, 18) }, 0.1)
            task.wait(0.3)
            tw(InputBG, { BackgroundColor3 = Color3.fromRGB(10, 10, 10) }, 0.3)
        end
    end)

    -- Wait until key is accepted
    while not keySuccess do task.wait(0.1) end

    -- Hide key frame
    for _, obj in ipairs(KeyFrame:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            tw(obj, { TextTransparency = 1 }, 0.25)
        elseif obj:IsA("Frame") then
            tw(obj, { BackgroundTransparency = 1 }, 0.25)
        end
    end
    task.wait(0.3)
    KeyFrame.Visible = false
end

-- ══════════════════════════════════════════
--  LOADER LOOP
-- ══════════════════════════════════════════
local function runLoader()
    LoadFrame.Visible = true
    BarBG.BackgroundTransparency = 0

    local currentProg = 0

    for i, step in ipairs(STEPS) do
        local targetProg = step[2]
        local delay      = step[3]

        -- Update step text
        tw(StepTxt, { TextTransparency = 1 }, 0.08)
        task.wait(0.1)
        StepTxt.Text = step[1]
        tw(StepTxt, { TextTransparency = 0 }, 0.15)

        -- Add to history every 2 steps
        if i % 2 == 0 then addHistory(step[1]) end

        -- Progress bar tween
        local tweenTime = (0.35 + (targetProg - currentProg) * 1.0) * CONFIG.LOAD_SPEED
        TweenService:Create(BarFill,
            TweenInfo.new(tweenTime, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2.new(targetProg, 0, 1, 0) }):Play()

        -- Percentage counter
        task.spawn(function()
            local startP  = currentProg
            local elapsed = 0
            while elapsed < tweenTime do
                elapsed = elapsed + task.wait(0.033)
                local t   = math.min(elapsed / tweenTime, 1)
                local pct = math.floor((startP + (targetProg - startP) * easeOut(t)) * 100)
                PctTxt.Text = pct.."%"
            end
            PctTxt.Text = math.floor(targetProg * 100).."%"
        end)

        currentProg = targetProg
        waitRnd(delay[1], delay[2])
    end

    -- Final line
    task.wait(0.2)
    tw(StepTxt, { TextTransparency = 1 }, 0.12)
    task.wait(0.15)
    StepTxt.Text = "Script loaded successfully."
    StepTxt.TextColor3 = Color3.fromRGB(180, 180, 180)
    tw(StepTxt, { TextTransparency = 0 }, 0.3)
    task.wait(0.9)
end

