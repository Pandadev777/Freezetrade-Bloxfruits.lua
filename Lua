local historyLines = {}
local function addHistory(txt)
    -- Keep max 4 lines
    if #historyLines >= 4 then
        local oldest = historyLines[1]
        tw(oldest, { TextTransparency = 1 }, 0.2)
        task.delay(0.22, function() oldest:Destroy() end)
        table.remove(historyLines, 1)
        -- Update layout order
        for i, l in ipairs(historyLines) do l.LayoutOrder = i end
    end
    local lbl = make("TextLabel", {
        Size                   = UDim2.new(1, 0, 0, 12),
        BackgroundTransparency = 1,
        Text                   = "· "..txt,
        Font                   = Enum.Font.Code,
        TextSize               = 8,
        TextColor3             = Color3.fromRGB(38, 38, 38),
        TextTransparency       = 1,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 103,
        LayoutOrder            = #historyLines + 1,
    }, HistoryFrame)
    tw(lbl, { TextTransparency = 0 }, 0.25)
    table.insert(historyLines, lbl)
end

